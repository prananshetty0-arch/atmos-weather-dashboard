# Copy this file to .env and fill in your own values.
# The real .env file is git-ignored — never commit real secrets.

# --- Server -------------------------------------------------------------
PORT=5000
NODE_ENV=development

# --- OpenWeatherMap (https://openweathermap.org/api) --------------------
# Free tier is enough for current weather, 5-day/3-hour forecast, and
# air pollution. The One Call 3.0 endpoint used for UV Index requires a
# separate opt-in subscription (also free, but must be enabled per-key).
WEATHER_API_KEY=your_openweathermap_api_key_here

# --- MongoDB --------------------------------------------------------------
# Local:  mongodb://127.0.0.1:27017/atmos
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/atmos
MONGO_URI=mongodb://127.0.0.1:27017/atmos

# --- CORS -----------------------------------------------------------------
# Comma-separated list of origins allowed to call the API in production.
# Not needed in development since the frontend is served by this same server.
CLIENT_ORIGIN=http://localhost:5000
